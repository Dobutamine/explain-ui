# Copy to .env.local and fill in. The "explain-labs_claude" bot — a Claude bot
# built specifically for the Explain project — lives on the Tailnet (port 8090),
# so this machine must be on the same Tailnet for the dev-server chat proxy
# (/api/chat in vite.config.ts) to reach it.
#
# Do NOT prefix these with VITE_ — that would inline them into the client bundle.
# They are read server-side only, inside the Vite dev middleware.

EXPLAIN_BOT_URL=http://lucys-mac-mini.tail990503.ts.net:8090
EXPLAIN_BOT_API_KEY=
