node_modules

# Vite dependency pre-bundle cache (regenerated on every dev/build). node_modules
# itself is tracked in this repo, so this rule is what actually keeps the cache out.
node_modules/.vite/

# Vite build output (regenerated by `npm run build`)
dist

# Scenario library is generated from the `explain-engine` submodule by
# scripts/sync-scenarios.mjs (predev/prebuild). Canonical source lives in
# explain-engine/model_definitions/. User/developer snapshots may also land here.
public/model_definitions/

# env files (bot URL + API key etc.) — never commit; keep *.example templates tracked
.env
.env.*
!.env.example
!.env.local.example

# macOS Finder + Obsidian editor cruft
.DS_Store
.obsidian/

# Python bytecode cache
__pycache__/
